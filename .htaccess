# PWA Manifest MIME type
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
</IfModule>

# Service Worker cache control (permitir actualización rápida)
<FilesMatch "sw\.js$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </IfModule>
</FilesMatch>

# Habilitar compresión para assets
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/manifest+json
</IfModule>
